NODE_ENV=development
PORT=3000

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_APP_ID=
SLACK_CONFIG_TOKEN=
SLACK_CONFIG_REFRESH_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REACTION_NAME=eyes

CLAUDE_MODEL=
CLAUDE_MAX_TURNS=24
CLAUDE_PERMISSION_MODE=bypassPermissions

# Optional Claude Code-compatible backend overrides.
# These are consumed directly by the Claude Code runtime rather than by this app.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=
ANTHROPIC_DEFAULT_HAIKU_MODEL=
ANTHROPIC_DEFAULT_SONNET_MODEL=
ANTHROPIC_DEFAULT_OPUS_MODEL=

LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=./logs

# Docker Compose helper: absolute host path containing candidate repositories.
# Example: /Users/yourname/git
HOST_REPO_ROOT=

# Optional Linux bind-mount compatibility for host-owned repositories.
# Set to your host uid:gid, for example from `id -u` and `id -g`.
# Leave blank to use the image's default non-root `app` user.
HOST_UID_GID=

# Local Node usage example:
# REPO_ROOT_DIR=~/git
#
# Docker Compose usage:
# REPO_ROOT_DIR=/workspace
REPO_ROOT_DIR=~/git
REPO_SCAN_DEPTH=2

SESSION_DB_PATH=./data/sessions.db
