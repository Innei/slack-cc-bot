NODE_ENV=development
PORT=3000

SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_REACTION_NAME=eyes

CLAUDE_MODEL=
CLAUDE_MAX_TURNS=24
CLAUDE_PERMISSION_MODE=bypassPermissions

LOG_LEVEL=info
LOG_TO_FILE=false
LOG_DIR=./logs

SESSION_DB_PATH=./data/sessions.db

SLACK_E2E_ENABLED=false
SLACK_E2E_CHANNEL_ID=
SLACK_E2E_TRIGGER_USER_TOKEN=
SLACK_E2E_STATUS_PROBE_PATH=./artifacts/slack-live-e2e/status-probe.jsonl
SLACK_E2E_RESULT_PATH=./artifacts/slack-live-e2e/result.json
SLACK_E2E_TIMEOUT_MS=180000
