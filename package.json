{
  "name": "slack-cc-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native Claude Agent SDK integration — monorepo.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:bot": "pnpm --filter @slack-cc-bot/bot build",
    "build:web": "pnpm --filter @slack-cc-bot/web-ui build",
    "db:generate": "pnpm --filter @slack-cc-bot/bot db:generate",
    "db:migrate": "pnpm --filter @slack-cc-bot/bot db:migrate",
    "db:studio": "pnpm --filter @slack-cc-bot/bot db:studio",
    "dev": "pnpm --filter @slack-cc-bot/bot dev",
    "dev:web": "pnpm --filter @slack-cc-bot/web-ui dev & pnpm --filter @slack-cc-bot/web-ui dev:server",
    "e2e": "tsx packages/live-cli/src/cli.ts run",
    "e2e:interactive": "tsx packages/live-cli/src/cli.ts run --interactive",
    "e2e:list": "tsx packages/live-cli/src/cli.ts list",
    "e2e:skill-gating:local": "tsx apps/bot/src/e2e/local/verify-claude-skill-gating.ts",
    "start": "pnpm --filter @slack-cc-bot/bot start",
    "test": "pnpm --filter @slack-cc-bot/bot test",
    "test:watch": "pnpm --filter @slack-cc-bot/bot test:watch",
    "typecheck": "pnpm -r run typecheck"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,yml,yaml}": [
      "eslint --fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@lobehub/eslint-config": "^2.1.5",
    "@lobehub/prettier-config": "^2.1.5",
    "eslint": "^10.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "4.21.0"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "unrs-resolver",
      "better-sqlite3"
    ]
  }
}
