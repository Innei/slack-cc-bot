{
  "name": "slack-cc-bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native Claude Agent SDK integration scaffold for local execution on macOS.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "nodemon",
    "e2e": "tsx src/e2e/live/run.ts",
    "e2e:commands": "tsx src/e2e/live/run-slash-commands.ts",
    "e2e:no-workspace": "tsx src/e2e/live/run-no-workspace-chat.ts",
    "e2e:picker": "tsx src/e2e/live/run-workspace-picker.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,yml,yaml}": [
      "eslint --fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.91",
    "@innei/pretty-logger-core": "0.4.2",
    "@slack/bolt": "4.6.0",
    "@t3-oss/env-core": "0.13.11",
    "better-sqlite3": "^12.8.0",
    "dotenv": "17.4.0",
    "drizzle-orm": "^0.45.2",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@lobehub/eslint-config": "^2.1.5",
    "@lobehub/prettier-config": "^2.1.5",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.5.1",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.1.0",
    "lint-staged": "^16.4.0",
    "nodemon": "3.1.14",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-sort-json": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "unrs-resolver",
      "better-sqlite3"
    ]
  }
}
