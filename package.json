{
  "name": "kagura-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F @innei/kagura build",
    "cli": "pnpm -F @innei/kagura exec tsx src/cli.ts",
    "cli:dist": "node apps/kagura/dist/cli.js",
    "cli:doctor": "pnpm -F @innei/kagura exec tsx src/cli.ts doctor",
    "cli:init": "pnpm -F @innei/kagura exec tsx src/cli.ts init",
    "cli:manifest": "pnpm -F @innei/kagura exec tsx src/cli.ts manifest",
    "cli:path": "pnpm -F @innei/kagura exec tsx src/cli.ts config path",
    "db:generate": "pnpm -F @innei/kagura db:generate",
    "db:migrate": "pnpm -F @innei/kagura db:migrate",
    "db:studio": "pnpm -F @innei/kagura db:studio",
    "dev": "pnpm -F @innei/kagura dev",
    "e2e": "pnpm -F @innei/kagura e2e",
    "e2e:interactive": "pnpm -F @innei/kagura e2e:interactive",
    "e2e:list": "pnpm -F @innei/kagura e2e:list",
    "format": "prettier --write --ignore-unknown .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "start": "pnpm -F @innei/kagura start",
    "test": "pnpm -r --if-present run test",
    "test:app": "pnpm -F @innei/kagura test",
    "test:cli": "pnpm -F @kagura/cli test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "typecheck:app": "pnpm -F @innei/kagura typecheck",
    "typecheck:cli": "pnpm -F @kagura/cli typecheck"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,yml,yaml}": [
      "eslint --fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@lobehub/eslint-config": "^2.1.5",
    "@lobehub/prettier-config": "^2.1.5",
    "eslint": "^10.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-sort-json": "^4.2.0",
    "simple-git-hooks": "^2.13.1"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "unrs-resolver",
      "better-sqlite3"
    ]
  }
}
