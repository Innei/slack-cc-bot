{
  "name": "kagura",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native Claude Agent SDK integration scaffold — monorepo root.",
  "type": "module",
  "scripts": {
    "build": "pnpm -F @kagura/bot run build",
    "build:web": "pnpm -F @kagura/web-ui run build",
    "db:generate": "pnpm -F @kagura/bot run db:generate",
    "db:migrate": "pnpm -F @kagura/bot run db:migrate",
    "db:studio": "pnpm -F @kagura/bot run db:studio",
    "dev": "pnpm -F @kagura/bot run dev",
    "dev:web": "pnpm -F @kagura/web-ui run dev",
    "e2e": "pnpm -F @kagura/bot run e2e",
    "e2e:interactive": "pnpm -F @kagura/bot run e2e:interactive",
    "e2e:list": "pnpm -F @kagura/bot run e2e:list",
    "e2e:skill-gating:local": "pnpm -F @kagura/bot run e2e:skill-gating:local",
    "start": "pnpm -F @kagura/bot run start",
    "test": "pnpm -F @kagura/bot run test",
    "test:watch": "pnpm -F @kagura/bot run test:watch",
    "typecheck": "pnpm -r run typecheck"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,yml,yaml}": [
      "eslint --fix"
    ],
    "*": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@lobehub/eslint-config": "^2.1.5",
    "@lobehub/prettier-config": "^2.1.5",
    "eslint": "^10.2.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-sh": "^0.18.1",
    "prettier-plugin-sort-json": "^4.2.0",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.2"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "simple-git-hooks",
      "unrs-resolver",
      "better-sqlite3"
    ]
  }
}
