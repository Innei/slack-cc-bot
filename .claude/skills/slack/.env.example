# ============================================================================
#  Slack Skill 环境变量
# ----------------------------------------------------------------------------
#  使用方法：
#    1. 把本文件复制为 `slack/.env`（或放到项目根目录 `.env`，两处都会加载）
#    2. 至少填一项 token（见下）
#    3. shell 里已导出的同名变量会覆盖文件里的值
# ============================================================================


# ---------- 1. Bot Token（主力；绝大多数子命令都用它） ----------
#
# 格式：xoxb-...
# 用于：get / replies / history / channels / users / resolve / files_download / cache_refresh
# 所需 scope（Bot Token Scopes，Slack App 后台配置，全部只读）：
#   channels:history  groups:history  im:history  mpim:history
#   channels:read     groups:read     im:read     mpim:read
#   users:read        users:read.email
#   files:read
SLACK_BOT_TOKEN=


# ---------- 2. User Token（仅 `search` 必须） ----------
#
# 格式：xoxp-...
# 用于：search（Slack 2020 起禁止 bot token 调 search.messages，只能 xoxp）
# 所需 scope（User Token Scopes，和 Bot Token Scopes 是两块独立区域）：
#   search:read
#   channels:history  groups:history  im:history  mpim:history
#   users:read        users:read.email
#   files:read
# 获取途径：
#   方式 1 · 同一个 App 的 OAuth & Permissions 页面下拉，User Token Scopes 栏加 scope
#           → 重新 Install to Workspace → 页面上 "User OAuth Token" 就是 xoxp-
#           （同一个 App 可以同时出 xoxb 和 xoxp）
#
# 只用其他命令（get/replies/history/...）的话可以留空。
#
SLACK_USER_TOKEN=

# ============================================================================
#  以下是可选调优，不填就用默认值
# ============================================================================

# 本地缓存目录（users.json / channels.json / files/ 存放处）
# 默认：$PWD/.agent-slack/cache/slack
#SLACK_SKILL_CACHE_DIR=

# --download-files 的落盘目录
# 默认：$SLACK_SKILL_CACHE_DIR/files
#SLACK_SKILL_FILES_DIR=

# --download-files 未指定 --types 时用的默认类型过滤
# 可选逗号分隔：text,image,video,all
# 默认：text
#SLACK_SKILL_DOWNLOAD_TYPES=text

# HTTP 请求超时（秒）
# 默认：60
#SLACK_SKILL_TIMEOUT=60

# 白名单频道 ID（逗号分隔，如 C0123,C0456）
# 设置后，任何不在列表里的频道都会被拒绝 —— 给敏感 workspace 加的保险
# 留空 = 允许 token 能看到的所有频道
#SLACK_SKILL_ALLOWED_CHANNELS=

# 本地 cache（users / channels / subteams）新鲜度 TTL（秒）
# 超过这个时间自动重跑一次 cache_refresh（对 channels / users --query / resolve 生效）
# 默认：259200（= 3 天）
#SLACK_SKILL_CACHE_TTL=259200

# 关闭自动 cache 刷新（设为 1 后 cache 只在手动跑 cache_refresh 时更新）
# 适合 CI / 想极致控制 API 调用量的场景
#SLACK_SKILL_CACHE_NO_AUTO=
