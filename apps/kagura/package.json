{
  "name": "@innei/kagura",
  "version": "0.2.1",
  "description": "Slack-native agent integration for Claude Agent SDK and OpenAI Codex CLI, scaffolded for local execution on macOS.",
  "keywords": [
    "slack",
    "claude",
    "codex",
    "agent",
    "bot",
    "anthropic",
    "openai"
  ],
  "homepage": "https://github.com/Innei/kagura#readme",
  "bugs": {
    "url": "https://github.com/Innei/kagura/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Innei/kagura.git"
  },
  "license": "MIT",
  "author": "Innei <i@innei.dev>",
  "type": "module",
  "bin": {
    "kagura": "./dist/cli.js",
    "kagura-app": "./dist/index.js"
  },
  "files": [
    "dist",
    "drizzle",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsdown",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "nodemon",
    "e2e": "tsx ../../packages/live-cli/src/cli.ts run",
    "e2e:interactive": "tsx ../../packages/live-cli/src/cli.ts run --interactive",
    "e2e:list": "tsx ../../packages/live-cli/src/cli.ts list",
    "prepublishOnly": "pnpm build",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.119",
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "0.91.1",
    "@clack/prompts": "^0.11.0",
    "@innei/pretty-logger-core": "0.4.2",
    "@kagura/cli": "workspace:*",
    "@slack/bolt": "4.7.1",
    "@t3-oss/env-core": "0.13.11",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.5.2",
    "commander": "^13.0.0",
    "dotenv": "17.4.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "markdown-to-slack-blocks": "1.5.0",
    "nodemon": "3.1.14",
    "open": "^10.1.0",
    "picocolors": "^1.1.0",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.5",
    "zod": "4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
