{
  "name": "@kagura/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Slack-native Claude Agent SDK bot with embedded Hono HTTP API.",
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "dev": "nodemon",
    "e2e": "tsx ../../packages/live-cli/src/cli.ts run",
    "e2e:interactive": "tsx ../../packages/live-cli/src/cli.ts run --interactive",
    "e2e:list": "tsx ../../packages/live-cli/src/cli.ts list",
    "e2e:skill-gating:local": "tsx src/e2e/local/verify-claude-skill-gating.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.tests.json --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.92",
    "@anthropic-ai/sdk": "0.82.0",
    "@hono/node-server": "^1.14.0",
    "@innei/pretty-logger-core": "0.4.2",
    "@slack/bolt": "4.6.0",
    "@t3-oss/env-core": "0.13.11",
    "better-sqlite3": "^12.8.0",
    "dotenv": "17.4.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "markdown-to-slack-blocks": "1.5.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "25.5.2",
    "drizzle-kit": "^0.31.10",
    "nodemon": "3.1.14",
    "tsdown": "0.21.7",
    "tsx": "4.21.0",
    "typescript": "^6.0.2",
    "vitest": "4.1.2"
  }
}
