SLACK_E2E_ENABLED=true
SLACK_E2E_CHANNEL_ID=
SLACK_E2E_TRIGGER_USER_TOKEN=
SLACK_E2E_STATUS_PROBE_PATH=./artifacts/slack-live-e2e/status-probe.jsonl
SLACK_E2E_RESULT_PATH=./artifacts/slack-live-e2e/result.json
SLACK_E2E_TIMEOUT_MS=180000

# Optional: override Claude Code runtime variables specifically for live E2E.
# Because .env.e2e is loaded with override=true, these values replace the same
# keys from .env only during live test runs.
# ANTHROPIC_AUTH_TOKEN=
# ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
# ANTHROPIC_MODEL=kimi-for-coding
# ANTHROPIC_DEFAULT_HAIKU_MODEL=kimi-for-coding
# ANTHROPIC_DEFAULT_SONNET_MODEL=kimi-for-coding
# ANTHROPIC_DEFAULT_OPUS_MODEL=kimi-for-coding

# E2E uses a separate database to avoid polluting production data.
# Defaults to ./data/e2e-sessions.db when not set.
# SESSION_DB_PATH=./data/e2e-sessions.db

# Override main bot tokens with E2E-specific app
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
SLACK_SIGNING_SECRET=
