{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "types": ["node"],
    "paths": {
      "~/*": ["./src/*"]
    },
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "incremental": true,
    "rootDir": "src",
    "outDir": "dist",
    "skipLibCheck": true
  },
  "exclude": ["dist", "node_modules"],
  "include": ["src/**/*.ts"]
}
